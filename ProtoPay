style.css (Professional UI)


*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{
background:#f5f7fb;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px;
background:#111;
color:white;
}

nav ul{
display:flex;
list-style:none;
gap:20px;
}

nav a{
color:white;
text-decoration:none;
}

.hero{
text-align:center;
padding:100px 20px;
background:linear-gradient(120deg,#3a7bd5,#00d2ff);
color:white;
}

.hero button{
padding:12px 25px;
border:none;
background:white;
color:black;
cursor:pointer;
margin-top:20px;
border-radius:6px;
}

.features{
display:flex;
justify-content:center;
gap:30px;
padding:60px;
}

.card{
background:white;
padding:30px;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
width:250px;
text-align:center;
}

.payment{
text-align:center;
padding:60px;
}

.payment input{
padding:10px;
width:200px;
margin-right:10px;
}

.payment button{
padding:10px 20px;
background:#3a7bd5;
color:white;
border:none;
cursor:pointer;
}

footer{
text-align:center;
padding:20px;
background:#111;
color:white;
}



script.js (Payment Prototype)



function buyAccess(){

alert("Redirecting to payment gateway...");

}



function processPayment(){

let amount = document.getElementById("amount").value;

if(amount == ""){
alert("Enter amount");
return;
}

alert("Payment of $" + amount + " processed successfully");

}
